{% extends 'base.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% block body %}
<div class="row">
    <div class="col-lg-8 mx-auto">
        <div class="card">
            <div class="card-header bg-gradient bg-primary text-white">
                <h3 class="mb-0"><i class="fas fa-tachometer-alt me-3"></i>Welcome back, {{ app.user.username }}!</h3>
            </div>
            <div class="card-body p-5">
                <div class="text-center mb-4">
                    <i class="fas fa-user-circle fa-5x text-primary mb-3"></i>
                    <p class="lead">You are successfully logged into <strong>CampusFlow</strong>.</p>
                </div>

                <hr>

                <h5 class="mt-4"><i class="fas fa-info-circle me-2"></i>Your Profile</h5>
                <div class="row g-3">
                    <div class="col-md-6">
                        <strong>Username:</strong> {{ app.user.username }}
                    </div>
                    <div class="col-md-6">
                        <strong>Email:</strong> {{ app.user.email }}
                    </div>
                    <div class="col-md-6">
                        <strong>Role(s):</strong>
                        {% for role in app.user.roles %}
                            <span class="badge bg-primary fs-6 ms-1">
                                {% if role == 'ROLE_ADMIN' %}Administrator
                                {% elseif role == 'ROLE_TEACHER' %}Teacher
                                {% elseif role == 'ROLE_USER' %}Student
                                {% endif %}
                            </span>
                        {% endfor %}
                    </div>
                    <div class="col-md-6">
                        <strong>Member since:</strong> {{ app.user.createdAt|date('F j, Y') }}
                    </div>
                </div>

                {% if is_granted('ROLE_ADMIN') %}
                    <hr class="my-4">
                    <div class="text-center">
                        <a href="{{ path('app_user_index') }}" class="btn btn-lg btn-primary px-5">
                            <i class="fas fa-users-cog me-2"></i>Manage Users
                        </a>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}